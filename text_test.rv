import std/string
import std/test { assert_eq_int, assert_eq_str }
import "./text" { Span, Line, Align, align_offset, wrap }
import "./style" { Style, Color }

fun test_line_width_sums_spans() {
    let l = Line.from_spans([Span.raw("ab"), Span.styled("你好", Style.new().fg(Color.Red))])
    assert_eq_int(l.width(), 6)
}

fun test_align_offsets() {
    assert_eq_int(align_offset(Align.Left, 4, 10), 0)
    assert_eq_int(align_offset(Align.Center, 4, 10), 3)
    assert_eq_int(align_offset(Align.Right, 4, 10), 6)
}

fun test_align_never_negative() {
    assert_eq_int(align_offset(Align.Right, 12, 10), 0)
}

fun test_wrap_short_text_is_one_line() {
    let lines = wrap("hello", 10)
    assert_eq_int(lines.len(), 1)
    assert_eq_str(lines[0], "hello")
}

fun test_wrap_breaks_on_spaces() {
    let lines = wrap("the quick brown fox", 10)
    assert_eq_int(lines.len(), 2)
    assert_eq_str(lines[0], "the quick")
    assert_eq_str(lines[1], "brown fox")
}

fun test_wrap_hard_splits_long_words() {
    let lines = wrap("abcdefghij", 4)
    assert_eq_int(lines.len(), 3)
    assert_eq_str(lines[0], "abcd")
    assert_eq_str(lines[1], "efgh")
    assert_eq_str(lines[2], "ij")
}

fun test_wrap_keeps_existing_newlines() {
    let lines = wrap("one\ntwo", 10)
    assert_eq_int(lines.len(), 2)
    assert_eq_str(lines[0], "one")
    assert_eq_str(lines[1], "two")
}

fun test_wrap_counts_wide_chars_by_columns() {
    // Four columns of CJK per line at width 4.
    let lines = wrap("你好吗你", 4)
    assert_eq_int(lines.len(), 2)
    assert_eq_str(lines[0], "你好")
    assert_eq_str(lines[1], "吗你")
}
